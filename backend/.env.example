# ----- Smart Regression System :: Backend env -----

# development | production
APP_ENV=development

# Versioned API prefix. Do not change within a major version.
API_V1_PREFIX=/api/v1

# CORS origins (comma-separated). Add your frontend URL in production.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Upload + dataset safety limits
MAX_UPLOAD_MB=25
MAX_ROWS=200000

# Lifetime (minutes) of in-memory dataset / model entries
REGISTRY_TTL_MINUTES=120

# Logging
LOG_LEVEL=INFO

# Reported by /api/v1/health
VERSION=1.0.0
